# =============================================================================
# PurveX Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# The start script (scripts/start_purvex.sh) auto-generates a JWT secret
# on first run if .env does not exist.
# =============================================================================

# ---------------------------------------------------------------------------
# Deployment
# ---------------------------------------------------------------------------
# "dev" | "staging" | "prod"
PURVEX_ENV=dev

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# SQLite (local dev):
#   DATABASE_URL=sqlite+aiosqlite:///./purvex.db
# PostgreSQL (production):
#   DATABASE_URL=postgresql+asyncpg://purvex:PASSWORD@localhost:5432/purvex
DATABASE_URL=sqlite+aiosqlite:///./purvex.db
# PostgreSQL connection pool (ignored for SQLite)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ---------------------------------------------------------------------------
# Redis (required in production for rate-limiting across replicas)
# ---------------------------------------------------------------------------
# Leave blank to fall back to in-memory rate limiting (dev only).
REDIS_URL=

# ---------------------------------------------------------------------------
# JWT / Authentication
# ---------------------------------------------------------------------------
# REQUIRED in production. Must be 32+ characters.
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=

# Token lifetime in minutes (default: 1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---------------------------------------------------------------------------
# Default Admin (dev/demo only — ignored in production)
# ---------------------------------------------------------------------------
# Set CREATE_DEFAULT_ADMIN=false in production. The start script prompts
# for real admin credentials on first run instead.
CREATE_DEFAULT_ADMIN=true
DEFAULT_ADMIN_EMAIL=admin
DEFAULT_ADMIN_PASSWORD=admin

# ---------------------------------------------------------------------------
# Email (required for password reset, invitations, GDPR exports)
# ---------------------------------------------------------------------------
# Provider: "smtp" | "sendgrid" | "console" (logs to stdout, dev only)
EMAIL_PROVIDER=console
EMAIL_FROM_ADDRESS=noreply@purvex.com
EMAIL_FROM_NAME=PurveX

# SMTP settings (when EMAIL_PROVIDER=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# SendGrid settings (when EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=

# ---------------------------------------------------------------------------
# CORS (production)
# ---------------------------------------------------------------------------
# Comma-separated list of allowed origins for production.
# Example: https://app.purvex.com,https://www.purvex.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---------------------------------------------------------------------------
# Field-Level Encryption
# ---------------------------------------------------------------------------
# Fernet key for encrypting 2FA secrets, SIEM credentials, etc.
# Generate one: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Required in production.
ENCRYPTION_KEY=

# ---------------------------------------------------------------------------
# Security Policies
# ---------------------------------------------------------------------------
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=30
PASSWORD_HISTORY_LENGTH=5
REQUIRE_2FA_FOR_ADMINS=false
REQUIRE_2FA_FOR_ALL_USERS=false

# ---------------------------------------------------------------------------
# Organization
# ---------------------------------------------------------------------------
ORGANIZATION_NAME=Default Organization
PRIMARY_CONTACT_EMAIL=
DEFAULT_TIMEZONE=UTC

# ---------------------------------------------------------------------------
# SIEM Integration
# ---------------------------------------------------------------------------
SIEM_TYPE=splunk
SPLUNK_URL=
SPLUNK_USERNAME=
SPLUNK_PASSWORD=
SPLUNK_TOKEN=

# ---------------------------------------------------------------------------
# AI Assistant
# ---------------------------------------------------------------------------
# Local Ollama (default):
OLLAMA_API_BASE_URL=http://localhost:11434
OLLAMA_MODEL_NAME=gemma2:2b
# OpenAI (optional):
OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# Observability (optional)
# ---------------------------------------------------------------------------
SENTRY_DSN=

# ---------------------------------------------------------------------------
# Registration & GDPR
# ---------------------------------------------------------------------------
# When false (default), /auth/register requires a valid invitation token.
ALLOW_PUBLIC_REGISTRATION=false
# Days before scheduled account deletion runs (grace period).
GDPR_DELETION_GRACE_DAYS=30

# ---------------------------------------------------------------------------
# Billing (Stripe)
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
# When true, authenticated API traffic requires active/trialing subscription (see docs).
PLAN_ENFORCEMENT_ENABLED=false

# ---------------------------------------------------------------------------
# Support contact form (destination for /support/ticket emails)
# ---------------------------------------------------------------------------
SUPPORT_EMAIL=

# ---------------------------------------------------------------------------
# Public URL (password reset links, Stripe redirects, invitation links)
# ---------------------------------------------------------------------------
PUBLIC_BASE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Audit
# ---------------------------------------------------------------------------
AUDIT_RETENTION_DAYS=30
AUDIT_RETENTION_ENABLED=true
