# Copy to .env.local for local dev, and set the same keys in Vercel
# (Project Settings -> Environment Variables) for production.

# Supabase project URL and anon (public) key, used by the PurveX Labs
# waitlist form (src/lib/waitlist.ts). Find both under
# Project Settings -> API in your Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
